# FAT Bridge AI Provider Configuration
# Copy this file to .env and fill in the values you actually use.

# Provider mode:
# - deterministic
# - openai-compatible
FAT_AI_PROVIDER=openai-compatible

# OpenAI-compatible endpoint settings
FAT_AI_API_KEY=replace_with_real_api_key
FAT_AI_BASE_URL=https://api.openai.com/v1
FAT_AI_MODEL=gpt-4.1-mini

# Optional runtime settings
PORT=8787
